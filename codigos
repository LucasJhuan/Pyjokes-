import tkinter as tk
import pyjokes as pj

#comando de gerar piada
piada = pj.get_joke()

#lista favoritos
favoritos = []

#loop principal
while True:
    piadoca = str(input('Gerar piada?(s ou n): ')).lower()
    
    if (piadoca == 'n'):
        break

    if (piadoca == 's'):
        print(piada)

        questao = str(input('Deseja favoritar esta grande piada?:(s ou n) ')).lower()

        if (questao == 's'):
            favoritos.append(piada)
        
        else:
            continue


print(f'Piadas favoritas: {favoritos}')


